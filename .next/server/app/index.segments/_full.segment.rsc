d:["$","section",null,{"className":"border-b border-border/60","children":["$","div",null,{"className":"mx-auto max-w-6xl px-6 py-20 md:py-28","children":[["$","div",null,{"className":"grid gap-12 lg:grid-cols-2 lg:gap-16","children":[["$","div",null,{"className":"flex flex-col justify-center","children":[["$","p",null,{"className":"mb-3 text-sm font-medium uppercase tracking-widest text-primary","children":"Why we exist"}],["$","h2",null,{"className":"font-heading text-balance text-3xl font-semibold tracking-tight md:text-4xl","children":"Built by operators who saw the problem firsthand."}],["$","div",null,{"className":"mt-8 space-y-6 text-pretty leading-relaxed text-muted-foreground","children":[["$","p",null,{"children":"I spent years watching good businesses lose revenue to a problem that shouldn't exist: unanswered calls. Not because they didn't care, but because staffing a phone line 24/7 is impossible for most practices."}],["$","p",null,{"children":"AI changed what's possible. For the first time, a small team can offer the responsiveness of a 24/7 call center without the overhead. But most solutions are built for enterprises and priced accordingly."}],["$","p",null,{"children":"We started with dental practices because they need this most. Calls come in all day, emergencies happen after hours, and every missed call is a patient who books somewhere else. Your front desk team is already stretched thin. You shouldn't have to choose between answering phones and helping the patients in front of you."}],["$","p",null,{"className":"text-foreground font-medium","children":"ZoltFlow exists to make sure no patient slips through the cracks, and no dental team has to drown in phones to make it happen."}],["$","div",null,{"className":"pt-2","children":[["$","p",null,{"className":"font-heading font-semibold text-foreground","children":"Dr. Sarah Chen"}],["$","p",null,{"className":"text-sm text-muted-foreground","children":"Founder, ZoltFlow"}]]}]]}]]}],["$","div",null,{"cl